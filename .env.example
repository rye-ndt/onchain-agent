# ==========================================
# Core infrastructure
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/aether_intent
REDIS_URL=redis://localhost:6379

# ==========================================
# LLM / embeddings
# ==========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Global OpenAI concurrency cap (per-replica). Default: 6.
OPENAI_CONCURRENCY=6
# Max agentic tool-use rounds per chat() call. Default: 10.
MAX_TOOL_ROUNDS=10
# Chat history window surfaced to the model. Default: 30.
MESSAGE_HISTORY_LIMIT=30

# ==========================================
# Pinecone — create index: dimension=1536, metric=cosine, serverless
# ==========================================
PINECONE_API_KEY=
PINECONE_INDEX_NAME=memora-v2
# Optional: skip the describe-index lookup on cold start.
PINECONE_HOST=https://<index-id>.svc.<environment>.pinecone.io

# ==========================================
# Telegram bot + user-client (for mini-app launcher)
# ==========================================
TELEGRAM_BOT_TOKEN=
# Obtain TG_API_ID / TG_API_HASH from my.telegram.org.
TG_API_ID=
TG_API_HASH=
# Serialized GramJS StringSession (see scripts/generateTgSession.ts).
TG_SESSION=

# ==========================================
# Privy auth (same App ID as the mini app — get App Secret from dashboard.privy.io)
# ==========================================
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Token-verification cache (per-replica).
PRIVY_VERIFY_CACHE_TTL_MS=300000
PRIVY_VERIFY_CACHE_MAX=5000

# ==========================================
# Search / external APIs
# ==========================================
TAVILY_API_KEY=
# Tavily response cache TTL. Default: 300.
TAVILY_CACHE_TTL_SECONDS=300
# Relay.link API base. Default: https://api.relay.link.
RELAY_API_URL=https://api.relay.link
# Relay quote cache TTL. Default: 15.
RELAY_QUOTE_CACHE_TTL_SECONDS=15

# ==========================================
# HTTP API
# ==========================================
HTTP_API_PORT=4000
# Strong random key for encrypting per-tool HTTP headers. Generate: openssl rand -hex 32.
HTTP_TOOL_HEADER_ENCRYPTION_KEY=
# Bearer token guarding /metrics.
METRICS_TOKEN=change-me-local-token

# Mini App launch URL sent to Telegram users (HTTPS, no trailing slash).
MINI_APP_URL=

# ==========================================
# DB pool (per-replica)
# Total Postgres connections = replicas × DB_POOL_MAX + 1 (worker pool).
# Do not raise without re-budgeting server max_connections.
# ==========================================
DB_POOL_MAX=25
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# ==========================================
# Process role — `combined` for local dev; workerCli/httpCli override in prod
# ==========================================
PROCESS_ROLE=combined

# ==========================================
# Blockchain
# 43113 = Avalanche Fuji (testnet), 43114 = Avalanche mainnet.
# ==========================================
CHAIN_ID=43114
# RPC_URL override is optional — when unset, chainConfig registry defaults apply.
# RPC_URL=
# Comma-separated secondary RPCs tried on primary failure.
RPC_URL_FALLBACKS=

# Rewards controller (read by claimRewards.solver.ts). Must be deployed on CHAIN_ID above.
REWARD_CONTROLLER_ADDRESS=

# ERC-4337 bundler + paymaster (ZeroDev v3: bundler URL == paymaster URL per status.md Rule 3).
# Chain segment must match CHAIN_ID above.
# Shape: https://rpc.zerodev.app/api/v3/<PROJECT_ID>/chain/<CHAIN_ID>
AVAX_BUNDLER_URL=
AVAX_PAYMASTER_URL=

# Session TTL for delegated session keys (seconds). Default: 7 days.
DELEGATION_TTL_SECONDS=604800

# ==========================================
# Token crawler (Pangolin list)
# ==========================================
# Override Pangolin token list URL (optional — defaults to official GitHub raw URL).
PANGOLIN_TOKEN_LIST_URL=
# Re-fetch interval in ms. Default: 15 min.
TOKEN_CRAWLER_INTERVAL_MS=900000

# ==========================================
# Yield optimizer
# ==========================================
# Comma-separated chain IDs where yield is enabled. Only chains with a `yield`
# entry in chainConfig.ts are honored (mainnet 43114 today).
YIELD_ENABLED_CHAIN_IDS=43114
YIELD_IDLE_USDC_THRESHOLD_USD=10
YIELD_POOL_SCAN_INTERVAL_MS=7200000
YIELD_USER_SCAN_INTERVAL_MS=86400000
YIELD_REPORT_UTC_HOUR=9
YIELD_NUDGE_COOLDOWN_SEC=86400
