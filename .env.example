PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/memora

# OpenAI (orchestrator, Whisper transcription, embeddings, memory enrichment)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# JWT
JWT_SECRET=your-secret-key

# Pinecone (user memory vector store)
# Create index manually: dimension=1536, metric=cosine, serverless
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=memora-v2
# Optional: provide the data-plane host to skip the describe-index lookup on cold start
PINECONE_HOST=https://<index-id>.svc.<environment>.pinecone.io

# Web search tool (when implemented)
WEB_SEARCH_API_KEY=...

# Max agentic tool-use rounds per chat() call (default 10)
MAX_TOOL_ROUNDS=10

# Unosend (email verification)
UNOSEND_API_KEY=un_your_api_key
UNOSEND_FROM_EMAIL=noreply@yourdomain.com

# Google OAuth
# Comma-separated list of OAuth scopes to request
GOOGLE_OAUTH_SCOPES=calendar,gmail.modify

# Redis (verification code storage, 30 min TTL)
REDIS_URL=redis://localhost:6379

# Caching
# TTL in seconds for queryCategories cache (default 300 seconds = 5 minutes)
QUERY_CATEGORIES_CACHE_TTL_SECONDS=300
