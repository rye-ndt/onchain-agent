DATABASE_URL=postgresql://user:password@localhost:5432/aether_intent
REDIS_URL=redis://localhost:6379

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max agentic tool-use rounds per chat() call (default 10)
MAX_TOOL_ROUNDS=10
# Messages after a turn before evaluating implicit feedback
FEEDBACK_WINDOW_SIZE=3

# Pinecone — create index: dimension=1536, metric=cosine, serverless
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=memora-v2
# Optional: skip the describe-index lookup on cold start
PINECONE_HOST=https://<index-id>.svc.<environment>.pinecone.io

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# Must match the redirect URI registered in Google Cloud Console
# e.g. http://localhost:4000/api/auth/google/calendar/callback
GOOGLE_REDIRECT_URI=...
# Comma-separated scopes: calendar, gmail.modify, etc.
GOOGLE_OAUTH_SCOPES=calendar,gmail.modify

TELEGRAM_BOT_TOKEN=...

# HTTP API server
HTTP_API_PORT=4000

# JWT — use a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=
# Token lifetime — examples: 7d, 30d, 1h
JWT_EXPIRES_IN=7d

# Minutes before a calendar event to fire its reminder (default: 30)
CALENDAR_REMINDER_OFFSET_MINS=30
# Hours ahead to scan for upcoming calendar events (default: 24)
CALENDAR_LOOK_AHEAD_HOURS=24
# How often the calendar crawler rescans, in minutes (default: 30)
CALENDAR_CRAWL_INTERVAL_MINS=30
# How often the notification runner checks for due notifications, in seconds (default: 60)
NOTIFICATION_POLL_INTERVAL_SECS=60

# Hours before a todo deadline to fire its reminder (default: 24)
TODO_REMINDER_OFFSET_HOURS=24

TAVILY_API_KEY=

# ==========================================
# Blockchain Configuration (Avalanche Fuji)
# ==========================================

# Network RPC
AVAX_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Bot Wallet (Holds CLAIMER_ROLE for rewards)
BOT_PRIVATE_KEY=your_bot_private_key_here  # Private key for 0xc018...ec078

# Core Token & Rewards
AEGIS_TOKEN_ADDRESS=0x8839ecFB1BefD232d5Fcf55C223BDD78bc3A2f69
REWARD_CONTROLLER_ADDRESS=0x519092C2185E4209B43d3ea40cC34D39978073A7

# Account Abstraction & Session Keys
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
JARVIS_ACCOUNT_FACTORY_ADDRESS=0x160E43075D9912FFd7006f7Ad14f4781C7f0D443
SESSION_KEY_MANAGER_ADDRESS=0xA5264f7599B031fDD523Ab66f6B6FA86ce56d291

# ERC-4337 Bundler (e.g. Pimlico or Alchemy)
AVAX_BUNDLER_URL=

# Bot's on-chain address (derived from BOT_PRIVATE_KEY)
BOT_ADDRESS=

# Platform fee recipient wallet
TREASURY_ADDRESS=

# Chain ID: 43113 = Avalanche Fuji testnet, 43114 = Avalanche Mainnet
CHAIN_ID=43113

# Solver APIs
TRADERJOE_API_URL=https://api.traderjoexyz.com
ONEINCH_API_KEY=