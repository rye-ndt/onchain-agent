    "drizzle-kit": "0.31.9",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.3.0",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "typescript-eslint": "8.54.0"
  },
  "dependencies": {
    "@googleapis/calendar": "9.7.0",
