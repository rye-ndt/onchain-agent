PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/memora

# Unosend (email verification)
UNOSEND_API_KEY=un_your_api_key
UNOSEND_FROM_EMAIL=noreply@yourdomain.com

# Redis (verification code storage, 30 min TTL)
REDIS_URL=redis://localhost:6379

# Caching
# TTL in seconds for queryCategories cache (default 300 seconds = 5 minutes)
QUERY_CATEGORIES_CACHE_TTL_SECONDS=300
